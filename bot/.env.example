# RPC
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_WSS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Bot wallet (cast wallet ile şifrelenmiş keystore kullan, raw key buraya KOYMA)
BOT_PRIVATE_KEY=

# Contract addresses (deploy sonrası doldur)
TREASURY_ADDRESS=
ROUTER_ADDRESS=

# Bot ayarları
POLL_INTERVAL_MS=3000
MIN_PROFIT_USD=5
MAX_GAS_GWEI=50
DRY_RUN=true
ETH_PRICE_USD=3000

# Telegram (BotFather'dan al)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Executor ---- #
DEADLINE_SECONDS=120
SLIPPAGE_BPS=50
TRADE_BUFFER_BPS=500
MAX_RETRIES=2
RETRY_BASE_DELAY_MS=1000

# ---- Risk ---- #
MAX_TRADE_AMOUNT_ETH=1.0
MAX_DAILY_LOSS_ETH=0.5
MAX_OPEN_TRADES=1
MIN_CONFIDENCE=60
MIN_LIQUIDITY=40
MAX_SLIPPAGE_BPS=50
COOLDOWN_MS=30000
MAX_CONSECUTIVE_FAILS=5

# ---- Strateji ---- #
WEIGHT_SPREAD=25
WEIGHT_CONFIDENCE=25
WEIGHT_LIQUIDITY=20
WEIGHT_HISTORY=20
WEIGHT_GAS_EFFICIENCY=10
MIN_SCORE=45
FLASHLOAN_MIN_PROFIT_USD=10
FLASHLOAN_MIN_CONFIDENCE=70
SIMPLE_MIN_PROFIT_USD=2
SIMPLE_MIN_CONFIDENCE=50

# ---- PriceGuard ---- #
PRICE_CACHE_TTL_MS=60000
MAX_PRICE_DEVIATION_PERCENT=2.0

# ---- x402 ---- #
X402_ENABLED=false
X402_MAX_PER_REQUEST=0.001
X402_DAILY_BUDGET=0.01
X402_PAYMENT_VALIDITY_SECONDS=300
# Premium fiyat endpoint'leri (format: name|url|confidence,name2|url2|confidence2)
# {tokens} placeholder'ı virgülle ayrılmış token adresleriyle değiştirilir
# X402_PRICE_ENDPOINTS=myprovider|https://api.example.com/prices?tokens={tokens}|90
